{
  "name": "@aikami/gamejs",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "godot-ts build",
    "watch": "godot-ts watch",
    "editor": "godot -e --path .",
    "dev": "bun run scripts/debug.js",
    "dev:emulator": "bun run scripts/debug.js --mode=emulator",
    "dev:production": "bun run scripts/debug.js --mode=production",
    "template:download": "bun run scripts/download-template.ts",
    "template:download:linux": "bun run scripts/download-template.ts --linux",
    "template:download:web": "bun run scripts/download-template.ts --web",
    "template:download:all": "bun run scripts/download-template.ts --all",
    "template:download:force": "bun run scripts/download-template.ts --force",
    "template:list": "bun run scripts/download-template.ts --list",
    "export": "bun run scripts/export.ts",
    "export:linux": "bun run scripts/export.ts --linux",
    "export:web": "bun run scripts/export.ts --web",
    "export:all": "bun run scripts/export.ts --all",
    "export:list": "bun run scripts/export.ts --list",
    "export:clean": "bun run scripts/export.ts --clean",
    "export:serve": "bun run scripts/serve.ts",
    "test": "bun test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:scenes": "bun run scripts/test.ts",
    "test:scenes:emulator": "bun run scripts/test.ts --mode=emulator",
    "test:scenes:list": "bun run scripts/test.ts --list",
    "test:ai": "bun run scripts/test.ts --mode=emulator ai",
    "test:managers": "bun run scripts/test.ts --mode=emulator managers",
    "test:quest-npc": "bun run scripts/test.ts --mode=emulator quest_npc",
    "test:game-systems": "bun run scripts/test.ts --mode=emulator game_systems",
    "test:godot": "godot --headless --test --test-case=\"[jsb]*\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "fix": "biome check --write . && biome format --write .",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@godot-js/godot-ts": "0.0.8",
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.1",
    "nodemon": "3.1.14",
    "npm-run-all2": "9.0.1",
    "tsc-alias": "1.8.17",
    "typescript": "6.0.3"
  },
  "godot-ts": {
    "src": "src",
    "out": "./.godot/GodotJS/src",
    "minifyClasses": false
  }
}
