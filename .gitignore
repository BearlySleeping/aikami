#
# === Monorepo .gitignore ===
#
# This file is structured logically.
# 1. Dependencies & Tool Caches
# 2. General Build Outputs
# 3. Project-Specific (SvelteKit, Astro, Godot, etc.)
# 4. Logs, Runtime, and Temp Files
# 5. Environment & Config
# 6. Testing & Coverage
# 7. OS & Editor Specific
# 8. Global Allow-List (Exceptions)
#

# --- 1. Dependencies & Tool Caches ---
## 📦 Dependencies
node_modules/
.pnp/
.pnp.js

## 🧰 Caches (npm, yarn, pnpm, etc.)
.npm/
.yarn-integrity
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

## ⚡ Caches (Vite, Parcel, ESLint, TS)
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# --- 2. General Build Outputs ---
## 🚀 General Build Outputs
build/
dist/
.output/
*.tgz
*.zip
*.tar.gz
*.rar

# --- 3. Project-Specific ---
## 🦕 Deno
# Deno's lockfile is usually committed for reproducible builds,
# but it can be ignored if your team prefers.
# deno.lock

## ⚡ Backend (Generic)
# Add any backend-specific build outputs here
# e.g., /apps/backend/bin/
# e.g., /apps/backend/target/

## ⚛️ Project: SvelteKit
.svelte-kit/
.vite
# `build/` is already covered above

## 🧑‍🚀 Project: Astro
.astro/
# `dist/` is already covered above

## 📖 Project: Storybook
.out/
.storybook-out/
storybook-static/
*storybook.log

##  TRANSLATION (Paraglide / inlang)
**/project.inlang/cache/
src/lib/paraglide

## 🖼️ Project: ComfyUI Image Microservice
# Models and caches are too large; per-directory .gitignore keeps structure.

## 🎮 Project: Godot
# This is a pruned version of the standard Godot template,
# as OS/IDE rules are already handled globally.

# Build configuration
/custom.py
misc/hooks/pre-commit-custom-*

# Godot generated files
.import/
/gdextension_interface.h
extension_api.json
bin/
*.gen.*
compile_commands.json
platform/windows/godot_res.res
build.ninja
.ninja
run_ninja_env.bat
tests/data/*.translation
tests/data/crypto/out*

# Godot-specific build output (C/C++, Python, etc.)
*.a
*.ax
*.d
*.dll
*.lib
*.lo
*.o
*.os
*.ox
*.Plo
*.so
st[A-Za-z0-9][A-Za-z0-9][A-Za-z0-9][A-Za-z0-9][A-Za-z0-9][A-Za-z0-9]
.venv
venv
__pycache__/
*.pyc
doc/_build/

# Godot platform-specific builds
.gradle/
local.properties
*.iml
.gradletasknamecache
project.properties
platform/android/java/*/.cxx/
platform/android/java/*/build/
platform/android/java/*/libs/
*.dSYM
*.bc
platform/web/node_modules/
*.debug

# --- 4. Logs, Runtime, and Temp Files ---
## 📜 Logs
logs/
*.log

## 🏃 Runtime Data
pids/
*.pid
*.seed
*.pid.lock
runtime/
*.tmp
*.temp
*.swp
*.swo
*~

# --- 5. Environment & Config ---
## 🔑 Environment Variables
# Ignore all .env files...
.env
.env.*
