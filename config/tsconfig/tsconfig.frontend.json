{
  "extends": ["./tsconfig.base.json", "./tsconfig.paths.shared.json"],
  "compilerOptions": {
    "paths": {
      "$logger": ["packages/logger/src/index.ts"],
      "$logger/*": ["packages/logger/src/*"],
      "$router": ["packages/frontend/services/src/lib/router/router-utils.ts"],
      "$router/*": ["packages/frontend/services/src/lib/router/router-utils/*"],
      "$routes": ["apps/frontend/pwa/src/lib/constants/routes.ts"],
      "$routes/*": ["apps/frontend/pwa/src/lib/constants/routes/*"],
      "@aikami/frontend/services": ["packages/frontend/services/src/index.ts"],
      "@aikami/frontend/services/*": ["packages/frontend/services/src/lib/*"],
      "@aikami/frontend/utils": ["packages/frontend/utils/src/index.ts"],
      "@aikami/frontend/utils/*": ["packages/frontend/utils/src/*"],
      "@aikami/frontend/repositories": ["packages/frontend/repositories/src/index.ts"],
      "@aikami/frontend/repositories/*": ["packages/frontend/repositories/src/*"]
    }
  }
}
