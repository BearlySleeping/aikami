#!/usr/bin/env bash
# ─── Aikami .envrc ──────────────────────────────────────────────────────
#
# Deterministic development environment via nix-direnv + Nix Flakes.
#
# What this does on every `cd` into the project:
#   1. Loads the Nix devShell (packages, env vars) — cached by nix-direnv
#   2. Resolves environment mode (emulator | development | production) from .env.local
#   3. Checks GCP authentication for cloud modes
#   4. Loads secrets from cached GSM values or falls back to mocks
#   5. Exposes convenient moon task-runner shortcuts
#   6. Validates runtime (bun version, moon sync status)
#
# See scripts/direnv/ for the helper libraries sourced below.
# ────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ── Early exit: already loaded ─────────────────────────────────────────
if [ -n "${AIKAMI_ENV_LOADED:-}" ]; then
  return 0
fi

# ── 0. Detect project root ─────────────────────────────────────────────
AIKAMI_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")"
export AIKAMI_ROOT

# ── 1. Nix-direnv integration ──────────────────────────────────────────
#
# nix-direnv wraps `use flake` with caching so that Nix evaluation
# happens only when flake.nix or its inputs change. Without it,
# `use flake` still works but evaluates on every shell entry.
#
# We attempt to source nix-direnv from three locations (priority order):
#   a) Already configured via ~/.config/direnv/direnvrc (use_flake exists)
#   b) NIX_DIRENV env var (set by flake.nix on prior loads)
#   c) Evaluate via `nix eval nixpkgs#nix-direnv` (one-time metadata fetch)

_aikami_setup_nix_direnv() {
  # Already configured? (direnvrc has sourced nix-direnv)
  if type use_flake &>/dev/null 2>&1; then
    return 0
  fi

  # Try NIX_DIRENV env var from a prior flake load
  if [ -n "${NIX_DIRENV:-}" ] && [ -f "$NIX_DIRENV/share/nix-direnv/direnvrc" ]; then
    source "$NIX_DIRENV/share/nix-direnv/direnvrc"
    return 0
  fi

  # Try evaluating nixpkgs#nix-direnv (fast — metadata-only, no build)
  local nix_direnv_path
  if nix_direnv_path=$(nix eval --raw nixpkgs#nix-direnv.outPath 2>/dev/null); then
    if [ -f "$nix_direnv_path/share/nix-direnv/direnvrc" ]; then
      source "$nix_direnv_path/share/nix-direnv/direnvrc"
      return 0
    fi
  fi

  # nix-direnv not available — `use flake` will still work but without caching
  if [ -z "${_AIKAMI_NIX_DIRENV_WARNED:-}" ]; then
    echo "⚠️  nix-direnv caching not enabled — flake will evaluate on every shell entry"
    echo ""
    echo "   To fix (one-time setup):"
    echo "   1. Install nix-direnv:  nix profile install nixpkgs#nix-direnv"
    echo "   2. Configure direnvrc:"
    echo '      mkdir -p ~/.config/direnv'
    echo '      echo "source \$HOME/.nix-profile/share/nix-direnv/direnvrc" >> ~/.config/direnv/direnvrc'
    echo "   3. Run: direnv allow"
    echo ""
    export _AIKAMI_NIX_DIRENV_WARNED=1
  fi
  return 0
}

_aikami_setup_nix_direnv

# ── 2. Load Nix flake devShell ─────────────────────────────────────────
# With nix-direnv → cached, <1s on subsequent loads
# Without → runs `nix print-dev-env` each time (~3-10s)
use flake

# ── 3. Aikami environment hooks ────────────────────────────────────────
# These run AFTER the Nix devShell is loaded. Every subsequent shell
# entry evaluates this block (fast — no Nix, just shell builtins).

# Source the core library (logging, mode resolution, validation)
source "${AIKAMI_ROOT}/scripts/direnv/lib.sh"

# Source secrets integration (GCP GSM or mock fallback)
source "${AIKAMI_ROOT}/scripts/direnv/secrets.sh"

# ── Execute hooks ──────────────────────────────────────────────────────

_aikami_load_mode
_aikami_gcp_check
_aikami_deps_warning
_aikami_secrets_load
_aikami_validate_runtime

# ── Shell integration (bash/zsh vs fish) ───────────────────────────────
# Fish can't execute bash functions, so shortcuts are only for bash/zsh.
case "${SHELL:-}" in
  *fish*)
    echo ""
    echo "  🐟 Fish shell detected — install shortcuts once:"
    echo "     ln -sf \$AIKAMI_ROOT/scripts/direnv/aikami.fish ~/.config/fish/conf.d/aikami.fish"
    echo ""
    echo "  🎴 Aikami ready  |  Mode: ${AIKAMI_MODE}  |  $(bun --version 2>/dev/null || echo 'bun N/A')"
    echo ""
    ;;
  *)
    # Bash / Zsh — source the aliases file directly
    source "${AIKAMI_ROOT}/scripts/direnv/moon.sh"
    _aikami_moon_banner
    ;;
esac

# ── Mark as loaded ─────────────────────────────────────────────────────
export AIKAMI_ENV_LOADED=1
