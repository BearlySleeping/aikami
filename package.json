{
  "name": "@aikami/monorepo",
  "private": true,
  "workspaces": [
    "packages/shared/*",
    "packages/backend/*",
    "packages/frontend/*",
    "apps/frontend/*",
    "apps/backend/*"
  ],
  "scripts": {
    "moon": "moon",
    "postinstall": "moon sync",
    "dev": "moon run pwa:dev",
    "build": "moon run :build",
    "build:affected": "moon run :build --affected",
    "test": "moon run :test",
    "test:watch": "moon run :test -- --watch",
    "lint": "moon run :lint",
    "format": "moon run :format",
    "fix": "moon run :fix",
    "typecheck": "moon run :typecheck",
    "ci": "bun run validate && bun run test",
    "scripts": "bun run scripts/src/index.ts",
    "setup": "bun run scripts/src/lib/setup/setup.ts",
    "dev:all": "bun run scripts/src/lib/ops/dev_all.ts",
    "knowledge:generate": "bun run scripts/src/lib/ops/generate_llms_txt.ts",
    "test:blackbox": "bun run scripts/src/lib/test_blackbox/run.ts",
    "tmux:start": "bun run scripts/src/lib/tmux/start.ts",
    "tmux:join": "bun run scripts/src/lib/tmux/join.ts",
    "tmux:stop": "bun run scripts/src/lib/tmux/stop.ts",
    "tmux:stop-all": "bun run scripts/src/lib/tmux/stop_all.ts",
    "tmux:list": "bun run scripts/src/lib/tmux/list.ts",
    "tmux:status": "bun run scripts/src/lib/tmux/status.ts",
    "clean": "rm -rf node_modules",
    "clean:all": "rm -rf node_modules .svelte-kit dist build .moon",
    "update:llm": "bunx @fission-ai/openspec update && bunx skills add pbakaus/impeccable",
    "deps:update": "syncpack update --dependency-types prod,dev --target latest && bun run deps:pin-dependencies",
    "deps:pin-dependencies": "bun run scripts/src/lib/ops/pin_dependencies.ts",
    "deps:sync": "syncpack fix --dependency-types prod,dev",
    "deps:check": "syncpack lint --dependency-types prod,dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@moonrepo/cli": "2.3.0",
    "@types/bun": "1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260602.1",
    "bun-automock": "0.2.7",
    "jiti": "2.7.0",
    "syncpack": "15.3.1",
    "tsconfig-moon": "1.4.2",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "onetime": "8.0.0",
    "typebox": "^1.1.39"
  },
  "overrides": {
    "onetime": "^5.1.2"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
