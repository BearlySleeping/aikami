{
  "name": "@aikami/monorepo",
  "private": true,
  "workspaces": [
    "packages/**",
    "apps/**"
  ],
  "scripts": {
    "moon": "moon",
    "postinstall": "moon sync",
    "dev": "moon run pwa:dev",
    "dev:pwa": "moon run pwa:dev",
    "dev:docs": "moon run docs:dev",
    "dev:landing": "moon run landing-page:dev",
    "build": "moon run :build",
    "build:affected": "moon run :build --affected",
    "build:pwa": "moon run pwa:build",
    "test": "moon run :test",
    "test:pwa": "moon run pwa:test",
    "test:watch": "moon run :test -- --watch",
    "test:ui": "moon run pwa:test -- --ui",
    "lint": "moon run :lint",
    "lint:fix": "moon run :lint -- --write",
    "lint:ci": "biome ci .",
    "format": "moon run :format",
    "format:write": "moon run :format -- --write",
    "format:ci": "biome ci .",
    "check": "moon run :check",
    "validate": "bun run format && bun run lint && bun run check",
    "validate:ci": "bun run format:ci && bun run lint:ci && bun run check",
    "ci": "bun run validate && bun run test",
    "ci:strict": "bun run validate:ci && bun run test",
    "clean": "rm -rf node_modules",
    "clean:all": "rm -rf node_modules .svelte-kit dist build .moon",
    "deps:update": "syncpack update --dependency-types prod,dev --target latest",
    "deps:sync": "syncpack fix --dependency-types prod,dev",
    "deps:check": "syncpack lint --dependency-types prod,dev",
    "deps:list": "syncpack list --dependency-types prod,dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@moonrepo/cli": "2.0.3",
    "@types/bun": "1.3.9",
    "bun-automock": "^0.2.5",
    "syncpack": "14.0.0",
    "tsconfig-moon": "1.4.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
