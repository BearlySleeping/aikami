{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "types": ["bun"],

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "paths": {
      "@aikami/types": ["../packages/shared/types/src/index.ts"],
      "@aikami/types/*": ["../packages/shared/types/src/lib/*"]
    }
  },
  "include": [
    "scripts/**/*.ts",
    "extensions/**/*.ts",
    "runners/**/*.ts",
    "skills/**/*.ts",
    "swarm/**/*.ts",
    "*.ts"
  ],
  "exclude": [
    "generated-skills",
    "workspaces",
    "node_modules"
  ]
}
