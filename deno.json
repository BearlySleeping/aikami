{
  "nodeModulesDir": "auto",
  "unstable": ["unsafe-proto", "sloppy-imports"],
  "workspace": [
    "./apps/backend/functions",
    "./apps/backend/rules",
    "./apps/frontend/docs",
    "./apps/frontend/landing_page",
    "./apps/frontend/pwa",

    "./packages/backend/ai",
    "./packages/backend/auth",
    "./packages/backend/configs",
    "./packages/backend/database",
    "./packages/backend/svelte-kit",
    "./packages/backend/utils",
    "./packages/constants",
    "./packages/frontend/services",
    "./packages/frontend/utils",
    "./packages/logger",
    "./packages/mocks",
    "./packages/schemas",
    "./packages/types",
    "./packages/utils"
  ],
  "tasks": {
    "moon": "moon run",

    "test": "deno task moon :test",
    "lint": "deno task moon :lint",
    "format": "deno task moon :format",
    "check": "deno task moon :check",
    "dev": "deno task dev:pwa",

    "dev:pwa": "deno task moon pwa:dev",
    "dev:docs": "deno task moon docs:dev",
    "dev:landing": "deno task moon landing-page:dev",
    "build": "deno task moon :build",
    "build:affected": "deno task moon :build --affected",

    "clean": "rm -rf node_modules"
  },
  "compilerOptions": {
    "module": "esnext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns",
      "deno.unstable"
    ]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "include": ["packages/", "apps/"],
    "exclude": [
      "node_modules",
      ".svelte-kit",
      "build",
      "dist",
      ".astro",
      ".vite",
      "coverage",
      "vendor",
      "project.inlang"
    ],
    "report": "pretty"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["packages/", "apps/"],
    "exclude": [
      "node_modules",
      ".svelte-kit",
      "build",
      "dist",
      ".astro",
      ".vite",
      "coverage",
      "vendor",
      "project.inlang"
    ]
  },
  "exclude": [
    "node_modules",
    ".svelte-kit",
    "build",
    "dist",
    ".astro",
    ".vite",
    "coverage",
    "vendor",
    "project.inlang"
  ],
