---
import type { ImageMetadata, ImageQuality } from 'astro';

interface Props {
  altText: string;
  class?: string;
  eager?: boolean;
  height?: number;
  imagePath: string;
  width?: number;
  quality?: ImageQuality;
}

const { altText, class: className, eager, height, imagePath, width, quality } = Astro.props;

// Import all blog and certificate images dynamically
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/**/*.{jpeg,jpg,png,gif,webp,avif}',
);

// Construct the full path from the imagePath
const fullPath = `/src/assets/${imagePath}`;

// Check if the image exists in our glob
// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (!images[fullPath]) {
  throw new Error(
    `"${fullPath}" does not exist in glob: "/src/assets/**/*.{jpeg,jpg,png,gif,webp}"`,
  );
}

// Get the image
const imageModule = await images[fullPath]();
const _image = imageModule.default;
---

<Picture
  alt={altText}
  class={className}
  height={height}
  loading={eager ? 'eager' : 'lazy'}
  src={image}
  width={width}
  quality={quality}
/>
