{
  "name": "@aikami/game",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --mode emulator",
    "dev:development": "vite dev --mode development",
    "dev:emulator": "vite dev --mode emulator",
    "dev:production": "vite dev --mode production",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:unit": "bun test --config tsconfig.test.json src",
    "test:ui": "playwright test --ui",
    "lint": "biome lint src tests",
    "format": "biome format src tests",
    "fix": "biome check --write src tests && biome format --write src tests",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/bun": "1.3.14",
    "playwright": "1.60.0",
    "typescript": "6.0.3",
    "vite": "8.0.14"
  },
  "dependencies": {
    "@aikami/constants": "workspace:*",
    "@aikami/frontend/engine": "workspace:*",
    "@aikami/frontend-api-core": "workspace:*",
    "bitecs": "^0.4.0",
    "pixi.js": "^8.18.1"
  }
}
