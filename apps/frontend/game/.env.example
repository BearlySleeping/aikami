# Public
## Firebase Configuration
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
PUBLIC_APP_ID=game

PUBLIC_MODE=
# Valid LogLevel values: NONE, DEBUG, INFO, NOTICE, WARNING, ERROR, CRITICAL, ALERT, EMERGENCY
PUBLIC_LOG_LEVEL=
PUBLIC_LOG_PERSIST_LEVEL=
PUBLIC_PARSE_LEVEL=safe

# reCAPTCHA v3 (for Firebase App Check)
# Get yours at: https://www.google.com/recaptcha/admin/create
# Use reCAPTCHA v3, add domains: localhost, {projectId}.web.app, {projectId}.firebaseapp.com
PUBLIC_RECAPTCHA_SITE_KEY=

# App Check debug token (for emulator/dev mode only)
# Generate with: node -e "console.log(require('crypto').randomUUID())"
PUBLIC_APP_CHECK_DEBUG_TOKEN=

PUBLIC_PWA_URL=
