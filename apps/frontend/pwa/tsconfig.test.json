{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "$services": ["./src/lib/client/services-mock"],
      "$services/*": ["./src/lib/client/services-mock/*"],
      "$router": ["../../../packages/frontend/services/src/lib/router/router-utils.ts"],
      "$router/*": ["../../../packages/frontend/services/src/lib/router/router-utils/*"],
      "$logger": ["../../../packages/logger/src/lib/svelte-kit.ts"],
      "$routes": ["./src/lib/constants/routes.ts"],
      "$routes/*": ["./src/lib/constants/routes/*"],
      "@aikami/frontend/services": ["../../../packages/frontend/services/src/index.ts"],
      "@aikami/frontend/services/*": ["../../../packages/frontend/services/src/lib/*"],
      "@aikami/frontend/utils": ["../../../packages/frontend/utils/src/index.ts"],
      "@aikami/frontend/utils/*": ["../../../packages/frontend/utils/src/lib/*"],
      "@aikami/frontend/repositories": ["../../../packages/frontend/repositories/src/index.ts"],
      "@aikami/frontend/repositories/*": ["../../../packages/frontend/repositories/src/*"],
      "@aikami/types": ["../../../packages/types/src/index.ts"],
      "@aikami/types/*": ["../../../packages/types/src/*"],
      "@aikami/utils": ["../../../packages/utils/src/index.ts"],
      "@aikami/utils/*": ["../../../packages/utils/src/*"],
      "@aikami/logger": ["../../../packages/logger/src/index.ts"],
      "@aikami/logger/*": ["../../../packages/logger/src/*"],
      "@aikami/constants": ["../../../packages/constants/src/index.ts"],
      "@aikami/constants/*": ["../../../packages/constants/src/*"],
      "@aikami/schemas": ["../../../packages/schemas/src/index.ts"],
      "@aikami/schemas/*": ["../../../packages/schemas/src/*"]
    }
  }
}
