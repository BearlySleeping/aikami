{
  "name": "@app/pwa",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:emulator": "vite dev --mode emulator",
    "dev:production": "vite dev --mode production",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome lint src",
    "format": "biome format src",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "fix": "biome check --write src",
    "test": "playwright test",
    "test:unit": "bun test --tsconfig tsconfig.test.json src/lib",
    "test:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "2.18.1",
    "@playwright/test": "1.60.0",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/kit": "2.61.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/png-chunks-extract": "1.0.2",
    "@types/text-encoding": "0.0.40",
    "daisyui": "5.5.20",
    "playwright": "1.60.0",
    "rollup-plugin-visualizer": "7.0.1",
    "svelte": "5.56.0",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "4.4.8",
    "tailwindcss": "4.3.0",
    "vite": "8.0.14",
    "vite-plugin-devtools-json": "1.0.0",
    "vite-plugin-iso-import": "1.3.0"
  },
  "dependencies": {
    "@aikami/constants": "workspace:*",
    "@aikami/engine": "workspace:*",
    "@aikami/frontend-services": "workspace:*",
    "@aikami/frontend-utils": "workspace:*",
    "@aikami/logger": "workspace:*",
    "@aikami/parser": "workspace:*",
    "@aikami/schemas": "workspace:*",
    "@aikami/types": "workspace:*",
    "@aikami/utils": "workspace:*",
    "@tauri-apps/api": "^2",
    "bitecs": "^0.4.0",
    "device-detector-js": "3.0.3",
    "eruda": "3.4.3",
    "pixi.js": "^8.18.1",
    "png-chunks-extract": "1.0.0",
    "text-encoding": "0.7.0"
  }
}
