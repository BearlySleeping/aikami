{
  "name": "@app/pwa",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome lint src",
    "format": "biome format src",
    "typecheck": "tsc --noEmit",
    "fix": "biome check --write src",
    "test": "playwright test",
    "test:unit": "bun test --tsconfig tsconfig.test.json src",
    "test:ui": "playwright test --ui",
    "validate": "bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "2.13.0",
    "@playwright/test": "1.58.2",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.53.3",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "4.2.1",
    "daisyui": "5.5.19",
    "playwright": "1.58.2",
    "rollup-plugin-visualizer": "7.0.0",
    "svelte": "5.53.5",
    "svelte-check": "4.4.4",
    "tailwindcss": "4.2.1",
    "vite": "7.3.1",
    "vite-plugin-devtools-json": "1.0.0",
    "vite-plugin-iso-import": "1.3.0"
  },
  "dependencies": {
    "@aikami/constants": "workspace:*",
    "@aikami/frontend-services": "workspace:*",
    "@aikami/frontend-utils": "workspace:*",
    "@aikami/logger": "workspace:*",
    "@aikami/schemas": "workspace:*",
    "@aikami/types": "workspace:*",
    "device-detector-js": "3.0.3",
    "eruda": "3.4.3"
  }
}
