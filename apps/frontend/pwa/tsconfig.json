{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "$components/*": ["./src/lib/components/*"],
      "$i18n": ["./src/lib/client/utils/i18n"],
      "$i18n/*": ["./src/lib/client/utils/i18n/*"],
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
      "$router": ["./src/lib/server/router.ts"],
      "$routes": ["./src/lib/constants/routes"],
      "$routes/*": ["./src/lib/constants/routes/*"],
      "$logger": ["./src/lib/logger"],
      "$services": ["./src/lib/client/services"],
      "$services/*": ["./src/lib/client/services/*"],
      "$types": ["./src/lib/types"],
      "$types/*": ["./src/lib/types/*"],
      "$utils": ["./src/lib/utils"],
      "$utils/*": ["./src/lib/utils/*"],
      "$views/*": ["./src/lib/views/*"],
      "$mock-services": ["./src/lib/client/services-mock"],
      "$mock-services/*": ["./src/lib/client/services-mock/*"],
      "@aikami/backend/svelte-kit/*": ["./src/lib/backend/*"],
      "@aikami/backend/database/*": ["./src/lib/backend/database/*"],
      "@aikami/backend/auth/*": ["./src/lib/backend/auth/*"],
      "@aikami/backend/ai/*": ["./src/lib/backend/ai/*"],
      "@aikami/backend/utils/*": ["./src/lib/backend/utils/*"],
      "@aikami/backend/configs/*": ["./src/lib/backend/configs/*"],
      "@aikami/constants": ["../../packages/constants/src"],
      "@aikami/schemas": ["../../packages/schemas/src"],
      "@aikami/types": ["../../packages/types/src"],
      "@aikami/utils": ["../../packages/utils/src"],
      "@aikami/logger": ["../../packages/logger/src"],
      "@aikami/frontend/services": ["../../packages/frontend/services/src"],
      "@aikami/frontend/utils": ["../../packages/frontend/utils/src"],
      "@aikami/frontend/repositories": ["../../packages/frontend/repositories/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "*.ts"],
  "exclude": ["node_modules", ".svelte-kit", "build", "src/lib/paraglide/messages"]
}
