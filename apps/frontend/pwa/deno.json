{
  "tasks": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "check:svelte": "deno task paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "deno task paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check:deno": "deno check src",
    "lint": "deno lint",
    "format": "deno fmt",
    "check": "deno task check:svelte && deno task check:deno"
  },
  "lint": {
    "rules": {
      "exclude": ["no-sloppy-imports"]
    }
  },
  "compilerOptions": {
    "rootDirs": [".", "./.svelte-kit/types"],
    "verbatimModuleSyntax": true,
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "types": ["./.svelte-kit/ambient.d.ts", "./.svelte-kit/non-ambient.d.ts"]
  }
}
