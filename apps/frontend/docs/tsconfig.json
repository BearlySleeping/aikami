{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Docs",
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$utils": ["./src/utils"],
      "$utils/*": ["./src/utils/*"],
      "$components/*": ["./src/components/*"],
      "$layouts/*": ["./src/layouts/*"],
      "$assets/*": ["./src/assets/*"],
      "$pages/*": ["./src/pages/*"]
    }
  },
  "include": [".astro/types.d.ts", "src", "astro.config.ts"],
  "exclude": ["dist", "**/node_modules/**"]
}
