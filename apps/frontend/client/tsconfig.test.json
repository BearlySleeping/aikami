{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
      "$services": ["./src/lib/services"],
      "$services/*": ["./src/lib/services/*"],
      "$router": ["../../../packages/frontend/services/src/lib/router/router-utils.ts"],
      "$router/*": ["../../../packages/frontend/services/src/lib/router/router-utils/*"],
      "$logger": ["../../../packages/shared/logger/src/lib/svelte-kit.ts"],
      "$logger/*": ["../../../packages/shared/logger/src/*"],
      "$routes": ["./src/lib/constants/routes.ts"],
      "$routes/*": ["./src/lib/constants/routes/*"],
      "@aikami/frontend/services": ["../../../packages/frontend/services/src/index.ts"],
      "@aikami/frontend/services/*": [
        "../../../packages/frontend/services/src/lib/*",
        "../../../packages/frontend/services/src/*"
      ],
      "@aikami/frontend/utils": ["../../../packages/frontend/utils/src/index.ts"],
      "@aikami/frontend/utils/*": [
        "../../../packages/frontend/utils/src/lib/*",
        "../../../packages/frontend/utils/src/*"
      ],
      "@aikami/frontend/repositories": ["../../../packages/frontend/repositories/src/index.ts"],
      "@aikami/frontend/repositories/*": [
        "../../../packages/frontend/repositories/src/lib/*",
        "../../../packages/frontend/repositories/src/*"
      ],
      "@aikami/types": ["../../../packages/shared/types/src/index.ts"],
      "@aikami/types/*": ["../../../packages/shared/types/src/*"],
      "@aikami/utils": ["../../../packages/shared/utils/src"],
      "@aikami/utils/*": ["../../../packages/shared/utils/src/*"],
      "@aikami/constants": ["../../../packages/shared/constants/src/index.ts"],
      "@aikami/constants/*": ["../../../packages/shared/constants/src/*"],
      "@aikami/schemas": ["../../../packages/shared/schemas/src/index.ts"],
      "@aikami/schemas/*": ["../../../packages/shared/schemas/src/*"],
      "@aikami/backend/configs/*": [
        "../../../packages/backend/configs/src/lib/*",
        "../../../packages/backend/configs/src/*"
      ],
      "@aikami/backend/auth/*": [
        "../../../packages/backend/auth/src/lib/*",
        "../../../packages/backend/auth/src/*"
      ],
      "@aikami/backend/database/*": [
        "../../../packages/backend/database/src/lib/*",
        "../../../packages/backend/database/src/*"
      ],
      "@aikami/backend/svelte-kit/*": [
        "../../../packages/backend/svelte-kit/src/lib/*",
        "../../../packages/backend/svelte-kit/src/*"
      ],
      "@aikami/backend/utils/*": [
        "../../../packages/backend/utils/src/lib/*",
        "../../../packages/backend/utils/src/*"
      ]
    }
  }
}
