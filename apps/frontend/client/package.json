{
  "name": "@aikami/client",
  "type": "module",
  "scripts": {
    "dev": "vite dev --mode emulator",
    "dev:staging": "vite dev --mode staging",
    "dev:emulator": "vite dev --mode emulator",
    "dev:production": "vite dev --mode production",
    "build": "vite build --mode production",
    "build:staging": "vite build --mode staging",
    "build:emulator": "vite build --mode emulator",
    "build:production": "vite build --mode production",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "dev:tauri": "bun run build:emulator && cd src-tauri && cargo build && ./target/debug/aikami",
    "build:tauri": "bun run build:emulator && cd src-tauri && cargo build",
    "preview:tauri": "bun run build:emulator && cd src-tauri && cargo build && ./target/debug/aikami",
    "preview": "vite preview --mode emulator",
    "prepare": "svelte-kit sync || echo ''",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome lint src",
    "format": "biome format src",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "fix": "biome check --write src --error-on-warnings",
    "test:unit": "bun test --preload ./src/lib/test_preload.ts --tsconfig tsconfig.test.json src/lib"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "2.20.2",
    "@playwright/test": "1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "2.69.2",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "26.1.1",
    "@types/png-chunks-extract": "1.0.2",
    "@types/text-encoding": "0.0.40",
    "daisyui": "5.6.16",
    "rollup-plugin-visualizer": "7.0.1",
    "svelte": "5.56.4",
    "svelte-check": "4.7.2",
    "tailwindcss": "4.3.2",
    "vite": "8.1.4",
    "vite-plugin-devtools-json": "1.0.0",
    "vite-plugin-iso-import": "1.3.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@aikami/constants": "workspace:*",
    "@aikami/frontend-components": "workspace:*",
    "@aikami/frontend-services": "workspace:*",
    "@aikami/frontend-utils": "workspace:*",
    "@aikami/frontend/engine": "workspace:*",
    "@aikami/logger": "workspace:*",
    "@aikami/parser": "workspace:*",
    "@aikami/schemas": "workspace:*",
    "@aikami/types": "workspace:*",
    "@aikami/utils": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-http": "^2",
    "bitecs": "^0.4.0",
    "device-detector-js": "3.0.3",
    "eruda": "3.4.3",
    "kokoro-js": "1.2.1",
    "firebase-admin": "14.1.0",
    "onnxruntime-web": "1.27.0",
    "pixi.js": "8.19.0",
    "png-chunks-extract": "1.0.0",
    "text-encoding": "0.7.0"
  }
}
