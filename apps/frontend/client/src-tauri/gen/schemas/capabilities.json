{
  "default": {
    "identifier": "default",
    "description": "Default capabilities for the main window",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "opener:default",
      "fs:default",
      "dialog:default",
      "http:default",
      {
        "identifier": "http:allow-fetch",
        "allow": [{ "url": "http://localhost:11434/**" }, { "url": "http://localhost:8188/**" }]
      }
    ]
  }
}
