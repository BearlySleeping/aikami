{
  "name": "@aikami/e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:client": "npx playwright test --project=client",
    "test:game": "npx playwright test --project=game",
    "test:visual": "bun run src/visual/runner.ts",
    "lpc:smoke": "bun run scripts/lpc_smoke.ts",
    "test:ai-services": "npx playwright test --project=ai-services",
    "lint": "biome lint .",
    "format": "biome format .",
    "fix": "biome check --write . --error-on-warnings",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "playwright": "1.61.1",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@aikami/constants": "workspace:*",
    "@aikami/types": "workspace:*",
    "sharp": "0.35.3",
    "typebox": "1.3.4"
  }
}
