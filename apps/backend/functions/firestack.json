{
  "$schema": "./node_modules/@snorreks/firestack/firestack.schema.json",
  "flavors": {
    "development": "aikami-dev",
    "production": "aikami-prod"
  },
  "region": "europe-west3",
  "nodeVersion": "24",
  "engine": "bun",
  "minify": true,
  "sourcemap": true,
  "emulators": [
    "auth",
    "functions",
    "firestore",
    "pubsub",
    "storage",
    "ui",
    "dataconnect"
  ],
  "emulatorPorts": {
    "auth": 9099,
    "functions": 5001,
    "firestore": 8080,
    "pubsub": 8085,
    "storage": 9199,
    "ui": 4000
  },
  "rulesTests": {
    "firestore": {
      "rulesFile": "src/rules/firestore.rules",
      "testPattern": "tests/rules/**/*.rules.test.ts",
      "projectId": "aikami-rules-test"
    },
    "storage": {
      "rulesFile": "src/rules/storage.rules",
      "testPattern": "tests/storage-rules/**/*.rules.test.ts",
      "projectId": "aikami-rules-test"
    }
  }
}
