{
  "tasks": {
    "check": "deno check src/**/*.ts",
    "format": "deno fmt",
    "lint": "deno lint",
    "build": "deno run -A --unstable-bundle compile.ts",
    "deploy": "deno run build && deno run -A deploy.ts",
    "test": "deno run -A scripts/test.ts",
    "populate-npcs": "deno run -A scripts/populate-npcs.ts"
  }
}
