{
  "name": "@app/backend-functions",
  "scripts": {
    "typecheck": "tsc --noEmit --skipLibCheck",
    "format": "biome format .",
    "lint": "biome lint .",
    "fix": "biome check --write .",
    "build": "bun run compile.ts",
    "deploy": "bun run deploy.ts",
    "test": "bun run scripts/test.ts",
    "validate": "bun run typecheck && bun run test",
    "populate-npcs": "bun run scripts/populate-npcs.ts"
  },
  "dependencies": {
    "@aikami/constants": "workspace:*",
    "@aikami/logger": "workspace:*",
    "@aikami/schemas": "workspace:*",
    "@aikami/types": "workspace:*",
    "@aikami/backend-configs": "workspace:*",
    "@aikami/backend-utils": "workspace:*",
    "@aikami/backend-database": "workspace:*",
    "@genkit-ai/googleai": "1.28.0",
    "axios": "1.13.6",
    "firebase-admin": "13.7.0",
    "firebase-functions": "7.0.6",
    "genkit": "1.29.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.9"
  }
}
