{
  "name": "@aikami/firebase",
  "type": "module",
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format .",
    "typecheck": "tsgo --noEmit --skipLibCheck",
    "fix": "biome check --write . --error-on-warnings",
    "build": "firestack deploy --dry-run",
    "deploy": "firestack deploy",
    "deploy:local": "node ../../../../firestack/dist/main.js deploy",
    "emulate": "firestack emulate --mode emulator --force",
    "emulate:local": "node ../../../../firestack/dist/main.js emulate",
    "sync": "firestack sync",
    "rules": "firestack rules",
    "delete": "firestack delete",
    "delete:local": "node ../../../../firestack/dist/main.js delete",
    "logs": "firestack logs",
    "generate": "firestack generate",
    "generate:local": "node ../../../../firestack/dist/main.js generate",
    "scripts": "firestack scripts",
    "scripts:local": "node ../../../../firestack/dist/main.js scripts",
    "test": "bun test tests/controllers.test.ts",
    "test:rules": "firestack test:rules --flavor staging",
    "populate-npcs": "bun run scripts/populate-npcs.ts"
  },
  "dependencies": {
    "@aikami/backend-ai": "workspace:*",
    "@aikami/backend-auth": "workspace:*",
    "@aikami/backend-configs": "workspace:*",
    "@aikami/backend-database": "workspace:*",
    "@aikami/backend-utils": "workspace:*",
    "@aikami/constants": "workspace:*",
    "@aikami/logger": "workspace:*",
    "@aikami/mocks": "workspace:*",
    "@aikami/schemas": "workspace:*",
    "@aikami/types": "workspace:*",
    "@genkit-ai/googleai": "1.28.0",
    "@snorreks/firestack": "0.0.74",
    "axios": "1.18.1",
    "firebase-admin": "14.2.0",
    "firebase-functions": "7.3.0",
    "genkit": "1.40.1",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "@types/pg": "8.20.0",
    "firebase-tools": "15.24.0"
  }
}
