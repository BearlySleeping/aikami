{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Functions",
  "extends": "../../../config/tsconfig/tsconfig.backend.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "target": "ES2023",
    "rootDir": "../../..",
    "paths": {
      "@aikami/backend/auth/*": ["../../../packages/backend/auth/src/lib/*"],
      "@aikami/backend/configs/*": ["../../../packages/backend/configs/src/lib/*"],
      "@aikami/backend/database": ["../../../packages/backend/database/src/index.ts"],
      "@aikami/backend/database/*": ["../../../packages/backend/database/src/lib/*"],
      "@aikami/backend/svelte-kit/*": ["../../../packages/backend/svelte-kit/src/lib/*"],
      "@aikami/backend/utils/*": ["../../../packages/backend/utils/src/lib/*"],
      "@aikami/email": ["../../../packages/backend/email/src/index.ts"],
      "@aikami/constants": ["../../../packages/shared/constants/src/index.ts"],
      "@aikami/constants/*": ["../../../packages/shared/constants/src/*"],
      "@aikami/logger": ["../../../packages/shared/logger/src/index.ts"],
      "@aikami/logger/*": ["../../../packages/shared/logger/src/*"],
      "@aikami/mocks": ["../../../packages/shared/mocks/src/index.ts"],
      "@aikami/mocks/*": ["../../../packages/shared/mocks/src/*"],
      "@aikami/schemas": ["../../../packages/shared/schemas/src/index.ts"],
      "@aikami/schemas/*": ["../../../packages/shared/schemas/src/*"],
      "@aikami/types": ["../../../packages/shared/types/src/index.ts"],
      "@aikami/types/*": ["../../../packages/shared/types/src/*"],
      "@aikami/utils": ["../../../packages/shared/utils/src/index.ts"],
      "@aikami/utils/*": ["../../../packages/shared/utils/src/*"],
      "@aikami/backend-team": ["../../../packages/backend/team/src/index.ts"],
      "@aikami/backend-team/*": ["../../../packages/backend/team/src/*"],
      "@aikami/backend/chat": ["../../../packages/backend/chat/src/index.ts"],
      "@aikami/backend/agent": ["../../../packages/backend/agent/src/index.ts"],
      "@aikami/backend/knowledge": ["../../../packages/backend/knowledge/src/index.ts"],
      "@aikami/backend/agent/*": ["../../../packages/backend/agent/src/*"],
      "$logger": ["./src/logger.ts"],
      "$logger/*": ["./src/logger/*"],
      "$lib/*": ["./src/lib/*"],
      "$env/static/private": ["../../../packages/backend/configs/src/lib/empty_environment.ts"]
    },
    "noEmit": true
  },
  "include": ["scripts/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
