{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Firebase",
  "extends": "../../../config/tsconfig/tsconfig.backend.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "target": "ES2023",
    "rootDir": "../..",
    "paths": {
      "@aikami/backend/auth": ["../backend/auth/src/index.ts"],
      "@aikami/backend/auth/*": ["../backend/auth/src/lib/*"],
      "@aikami/backend/configs": ["../backend/configs/src/index.ts"],
      "@aikami/backend/configs/*": ["../backend/configs/src/lib/*"],
      "@aikami/backend/database": ["../backend/database/src/index.ts"],
      "@aikami/backend/database/*": ["../backend/database/src/lib/*"],
      "@aikami/backend/utils": ["../backend/utils/src/index.ts"],
      "@aikami/backend/utils/*": ["../backend/utils/src/lib/*"],
      "@aikami/constants": ["../../shared/constants/src/index.ts"],
      "@aikami/constants/*": ["../../shared/constants/src/lib/*"],
      "@aikami/schemas": ["../../shared/schemas/src/index.ts"],
      "@aikami/schemas/*": ["../../shared/schemas/src/lib/*"],
      "@aikami/types": ["../../shared/types/src/index.ts"],
      "@aikami/types/*": ["../../shared/types/src/lib/*"],
      "@aikami/utils": ["../../shared/utils/src/index.ts"],
      "@aikami/utils/*": ["../../shared/utils/src/lib/*"],
      "$logger": ["../../shared/logger/src/index.ts"],
      "$logger/*": ["../../shared/logger/src/lib/*"],
      "$env/*": ["../../../config/tsconfig/stubs/env/*"]
    },
    "noEmit": true
  },
  "include": ["scripts/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
