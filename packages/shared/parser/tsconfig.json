{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Parser",
  "extends": "../../../config/tsconfig/tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "dist",
    "paths": {
      "@aikami/schemas": ["../schemas/src/index.ts"],
