{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Mocks",
  "extends": "../../../config/tsconfig/tsconfig.base.json",
  "compilerOptions": {
    "types": ["bun-types"],
    "rootDir": "../../..",
    "outDir": "dist",
    "paths": {
      "@aikami/constants": ["../constants/src/index.ts"],
      "@aikami/constants/*": ["../constants/src/lib/*"],
      "@aikami/schemas": ["../schemas/src/index.ts"],
      "@aikami/schemas/*": ["../schemas/src/lib/*"],
      "@aikami/types": ["../types/src/index.ts"],
      "@aikami/types/*": ["../types/src/lib/*"],
      "@aikami/utils": ["../utils/src/index.ts"],
      "@aikami/utils/*": ["../utils/src/lib/*"],
      "@aikami/backend/configs/*": ["../../backend/configs/src/lib/*"],
      "@aikami/backend/utils/*": ["../../backend/utils/src/lib/*"],
      "@aikami/backend/database": ["../../backend/database/src/index.ts"],
      "@aikami/backend/database/*": ["../../backend/database/src/lib/*"],
      "$env/*": ["../../../config/tsconfig/stubs/env/*"],
      "$logger": ["../logger/src/index.ts"],
      "$logger/*": ["../logger/src/lib/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
