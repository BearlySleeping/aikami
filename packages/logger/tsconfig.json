{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Logger",
  "extends": "../../config/tsconfig/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../../",
    "outDir": "dist",
    "paths": {
