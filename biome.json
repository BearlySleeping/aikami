{
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/**",
      "packages/**",
      "scripts/**",
      ".pi/**",
      "!.pi/generated-skills",
      "!**/temp/*",
      "!**/tmp/*",
      "!**/dist/*",
      "!**/build/*"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto",
    "bracketSpacing": true,
    "useEditorconfig": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noThenProperty": "error",
        "noExplicitAny": "error",
        "noConsole": "error"
      },
      "style": {
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["snake_case"]
          }
        },
        "useNumberNamespace": "error",
        "noSubstr": "error",
        "useBlockStatements": "error",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false
          }
        },
        "useConsistentTypeDefinitions": {
          "level": "error",
          "options": {
            "style": "type"
          }
        },
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@aikami/backend-ai": "Use @aikami/backend/ai instead",
              "@aikami/backend-auth": "Use @aikami/backend/auth instead",
              "@aikami/backend-configs": "Use @aikami/backend/configs instead",
              "@aikami/backend-database": "Use @aikami/backend/database instead",
              "@aikami/backend-svelte-kit": "Use @aikami/backend/svelte-kit instead",
              "@aikami/backend-utils": "Use @aikami/backend/utils instead",
              "@aikami/frontend-configs": "Use @aikami/frontend/configs instead",
              "@aikami/frontend-dataconnect": "Use @aikami/frontend/dataconnect instead",
              "@aikami/frontend-engine": "Use @aikami/frontend/engine instead",
              "@aikami/frontend-repositories": "Use @aikami/frontend/repositories instead",
              "@aikami/frontend-services": "Use @aikami/frontend/services instead",
              "@aikami/frontend-utils": "Use @aikami/frontend/utils instead"
            }
          }
        }
      },
      "complexity": {
        "useArrowFunction": "error",
        "noUselessSwitchCase": "error",
        "useFlatMap": "error",
        "useDateNow": "error",
        "noForEach": "error",
        "noStaticOnlyClass": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "useImportExtensions": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false,
      "attributePosition": "auto",
      "operatorLinebreak": "after"
    },
    "globals": ["Bun", "process", "fetch", "prompt"]
  },
  "html": {
    "experimentalFullSupportEnabled": true,
    "formatter": {
      "enabled": true,
      "indentScriptAndStyle": true
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "suspicious": {
            "noUnknownAtRules": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.d.ts"],
      "linter": {
        "rules": {
          "style": {
            "useConsistentTypeDefinitions": "off",
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/e2e/**", "**/scripts/**", ".pi/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.svelte", "**/*.astro"],
      "linter": {
        "rules": {
          "a11y": {
            "useButtonType": "off",
            "noSvgWithoutTitle": "off",
            "useAnchorContent": "off",
            "useValidAriaValues": "off"
          }
        }
      }
    },
    {
      "includes": [".pi/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/+page.svelte",
        "**/+layout.svelte",
        "**/+error.svelte",
        "**/+page.ts",
        "**/+layout.ts",
        "**/+page.server.ts",
        "**/+layout.server.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.svelte", "**/*.svelte.ts"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["**/app.html"],
      "linter": {
        "rules": {
          "a11y": {
            "useValidLang": "off"
          }
        }
      }
    },
    {
      "includes": ["**/service-worker.js"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        "scripts/src/lib/agents/**",
        "scripts/src/lib/herdr/**",
        "scripts/src/lib/agent_scratchpad.ts",
        "scripts/src/index.ts",
        "scripts/src/lib/test_blackbox/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/frontend/client/src/lib/services/image/image_generation_service.test.ts",
        "apps/frontend/client/src/lib/**/*.test.ts",
        "apps/frontend/client/src/lib/test_preload.ts",
        "packages/shared/constants/src/lib/world_gen.ts",
        "packages/backend/ai/src/lib/agent_router.ts",
        "packages/frontend/engine/src/math/goap/**",
        ".pi/extensions/herdr_orchestrator.ts",
        ".pi/runners/convention_gate.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          },
          "suspicious": {
            "noControlCharactersInRegex": "off"
          }
        }
      }
    }
  ]
}
