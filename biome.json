{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/frontend/pwa/**",
      "apps/frontend/landing_page/**",
      "apps/frontend/game2/**",
      "apps/backend/functions/**",
      "apps/backend/rules/**",
      "packages/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto",
    "bracketSpacing": true,
    "useEditorconfig": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noThenProperty": "error",
        "noExplicitAny": "error",
        "noConsole": "warn"
      },
      "style": {
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useFilenamingConvention": "error",
        "useNumberNamespace": "error",
        "noSubstr": "error"
      },
      "complexity": {
        "useArrowFunction": "error",
        "noUselessSwitchCase": "error",
        "useFlatMap": "error",
        "useDateNow": "error",
        "noForEach": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "useImportExtensions": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false,
      "attributePosition": "auto",
      "operatorLinebreak": "after"
    }
  },
  "html": {
    "experimentalFullSupportEnabled": true,
    "formatter": {
      "enabled": true,
      "indentScriptAndStyle": true
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": [
        "apps/frontend/landing_page/astro.config.ts",
        "apps/frontend/docs/astro.config.js",
        "apps/frontend/docs/src/content.config.js"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/frontend/game2/**"],
      "formatter": {
        "indentWidth": 4,
        "lineWidth": 120
      },
      "linter": {
        "rules": {
          "complexity": {
            "noForEach": "off",
            "noStaticOnlyClass": "off"
          },
          "suspicious": {
            "noExplicitAny": "warn"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/frontend/pwa/**", "packages/utils/**", "packages/constants/**"],
      "linter": {
        "rules": {
          "complexity": {
            "noForEach": "off",
            "noStaticOnlyClass": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "noImplicitAnyLet": "off",
            "useIterableCallbackReturn": "off"
          },
          "correctness": {
            "noUnusedVariables": "off"
          },
          "a11y": {
            "useValidLang": "off",
            "noSvgWithoutTitle": "off",
            "useButtonType": "off"
          },
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
