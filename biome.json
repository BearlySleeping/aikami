{
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "master"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/**",
      "packages/**",
      "scripts/**",
      ".pi/**",
      "!.pi/generated-skills",
      "!**/temp/*",
      "!**/tmp/*",
      "!**/dist/*",
      "!**/build/*"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto",
    "bracketSpacing": true,
    "useEditorconfig": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noThenProperty": "error",
        "noExplicitAny": "error",
        "noConsole": "error"
      },
      "style": {
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": [
              "snake_case"
            ]
          }
        },
        "useNumberNamespace": "error",
        "noSubstr": "error",
        "useBlockStatements": "error",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false
          }
        },
        "useConsistentTypeDefinitions": {
          "level": "error",
          "options": {
            "style": "type"
          }
        },
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@aikami/backend-ai": "Use @aikami/backend/ai instead",
              "@aikami/backend-auth": "Use @aikami/backend/auth instead",
              "@aikami/backend-configs": "Use @aikami/backend/configs instead",
              "@aikami/backend-database": "Use @aikami/backend/database instead",
              "@aikami/backend-chat": "Use @aikami/backend/chat instead",
              "@aikami/backend-image": "Use @aikami/backend/image instead",
              "@aikami/backend-svelte-kit": "Use @aikami/backend/svelte-kit instead",
              "@aikami/backend-utils": "Use @aikami/backend/utils instead",
              "@aikami/frontend-configs": "Use @aikami/frontend/configs instead",
              "@aikami/frontend-dataconnect": "Use @aikami/frontend/dataconnect instead",
              "@aikami/frontend-engine": "Use @aikami/frontend/engine instead",
              "@aikami/frontend-repositories": "Use @aikami/frontend/repositories instead",
              "@aikami/frontend-services": "Use @aikami/frontend/services instead",
              "@aikami/frontend-utils": "Use @aikami/frontend/utils instead",
              "@aikami/frontend-components": "Use @aikami/frontend/components instead"

            }
          }
        }
      },
      "complexity": {
        "useArrowFunction": "error",
        "noUselessSwitchCase": "error",
        "useFlatMap": "error",
        "useDateNow": "error",
        "noForEach": "error",
        "noStaticOnlyClass": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "useImportExtensions": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false,
      "attributePosition": "auto",
      "operatorLinebreak": "after"
    },
    "globals": [
      "Bun",
      "process",
      "fetch",
      "prompt"
    ]
  },
  "html": {
    "experimentalFullSupportEnabled": true,
    "formatter": {
      "enabled": true,
      "indentScriptAndStyle": true
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": [
        "**/*.d.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useConsistentTypeDefinitions": "off",
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/e2e/**",
        "**/scripts/**",
        ".pi/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
